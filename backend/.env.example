# FRED API Key — get yours free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Tiingo API Key — get yours free at https://app.tiingo.com
TIINGO_API_KEY=your_tiingo_key_here

# Database
DATABASE_URL=sqlite:///./data/risk_dashboard.db

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Data refresh schedule (cron expression — default: daily at 6am)
DATA_REFRESH_CRON=0 6 * * *
